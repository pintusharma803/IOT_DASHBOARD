<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
        }

        .container {
            width: 100%;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: radial-gradient(circle at bottom left, #1d4f92 0%, #123165 40%, #08172e 100%);
        }

        .content {
            text-align: center;
        }

        .icon {
            width: 58px;
            height: 58px;
            margin: 0 auto 25px;
            border: 3px solid #ff3d5b;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            color: #ff3d5b;
            font-size: 24px;
        }

        h1 {
            color: #fff;
            font-size: 64px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .subtitle {
            color: rgba(255, 255, 255, .45);
            font-size: 24px;
            font-weight: 300;
        }

        .login-btn {
            margin-top: 40px;
            padding: 14px 42px;
            font-family: 'Poppins', sans-serif;
            font-size: 18px;
            font-weight: 600;
            color: #fff;
            background: #ff3d5b;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: .3s;
        }

        .login-btn:hover {
            background: #ff2248;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255, 61, 91, .35);
        }

        .login-btn:active {
            transform: scale(.98);
        }

        @media(max-width:768px) {

            h1 {
                font-size: 42px;
            }

            .subtitle {
                font-size: 18px;
            }

            .icon {
                width: 48px;
                height: 48px;
                font-size: 18px;
            }

            .login-btn {
                width: 220px;
                font-size: 16px;
                padding: 13px 20px;

            }
        }
    </style>

</head>

<body>

    <div class="container">

        <div class="content">

            <!-- <div class="icon">
            <i class="fa-solid fa-film"></i>
        </div> -->

            <h1>Welcome!</h1>

            <p class="subtitle">Creating your profile....</p>

            <a href="/login">
                <button class="login-btn" id="loginbtn" onclick="login()">
                    Login to Device
                </button>
            </a>

        </div>

    </div>

</body>

</html>